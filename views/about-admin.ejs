<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="referrer" content="no-referrer">
    <title>Hakkında Yönetimi - 59 Haber Kutusu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg: #070b16;
            --bg-alt: #0d1223;
            --panel: rgba(18, 25, 44, 0.92);
            --panel-border: rgba(255, 255, 255, 0.1);
            --gold: #d4af37;
            --white: #F8FAFC;
            --text: #E5E7EB;
            --text-muted: #9CA3AF;
            --accent: #EF4444;
            --accent-dark: #B91C1C;
        }

        html,
        body {
            min-height: 100%;
            height: 100%;
            overflow-x: hidden;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text);
            background: radial-gradient(circle at top left, rgba(212, 175, 55, 0.12), transparent 18%),
                radial-gradient(circle at 80% 10%, rgba(255, 255, 255, 0.06), transparent 18%),
                linear-gradient(180deg, #0a111f 0%, #070b16 100%);
            background-attachment: fixed;
            line-height: 1.5;
            overflow-y: auto;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(circle at 20% 10%, rgba(255, 255, 255, 0.05), transparent 9%),
                radial-gradient(circle at 90% 40%, rgba(212, 175, 55, 0.05), transparent 10%);
            pointer-events: none;
        }

        .admin-header {
            background: rgba(6, 10, 19, 0.95);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            color: var(--white);
            padding: 18px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 10;
            backdrop-filter: blur(18px);
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.25);
        }

        .admin-header h1 {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: 0.03em;
        }

        .admin-header h1 span {
            color: var(--gold);
        }

        .admin-links {
            display: flex;
            gap: 16px;
            align-items: center;
            flex-wrap: wrap;
        }

        .admin-links a {
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
            transition: color 0.2s, transform 0.2s;
        }

        .admin-links a:hover {
            color: var(--white);
            transform: translateY(-1px);
        }

        .admin-menu-toggle {
            display: none;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--white);
            border-radius: 12px;
            padding: 12px 14px;
            cursor: pointer;
            font-size: 18px;
            line-height: 1;
        }

        .container {
            max-width: 980px;
            margin: 28px auto;
            background: var(--panel);
            border: 1px solid var(--panel-border);
            border-radius: 28px;
            padding: 32px;
            box-shadow: 0 28px 70px rgba(0, 0, 0, 0.24);
            backdrop-filter: blur(18px);
        }

        .title {
            font-size: 22px;
            font-weight: 800;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid rgba(212, 175, 55, 0.18);
            color: var(--white);
        }

        .hint {
            margin: 0 0 14px;
            font-size: 13px;
            color: var(--text-muted);
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 18px;
            padding: 14px 16px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.12em;
        }

        .form-group textarea,
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 14px 16px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            font-family: inherit;
            font-size: 14px;
            background: rgba(255, 255, 255, 0.04);
            color: var(--text);
            transition: border-color 0.25s, box-shadow 0.25s;
        }

        .form-group textarea {
            min-height: 160px;
            resize: vertical;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: rgba(212, 175, 55, 0.55);
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.08);
        }

        .btn-submit {
            width: 100%;
            padding: 16px 18px;
            background: linear-gradient(120deg, rgba(212, 175, 55, 0.95), rgba(255, 211, 118, 0.95));
            color: #111827;
            border: none;
            border-radius: 18px;
            font-size: 15px;
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 16px 30px rgba(212, 175, 55, 0.2);
            transition: transform 0.2s, opacity 0.2s;
        }

        .btn-submit:hover {
            transform: translateY(-1px);
            opacity: 0.95;
        }

        .btn-cancel {
            display: inline-block;
            width: 100%;
            text-align: center;
            padding: 14px 0;
            margin-top: 12px;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 700;
            border: 1.5px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            transition: border-color 0.2s, color 0.2s;
        }

        .btn-cancel:hover {
            border-color: rgba(212, 175, 55, 0.3);
            color: var(--text);
        }

        @media (max-width: 768px) {
            .admin-header {
                flex-wrap: wrap;
                gap: 14px;
                padding: 18px 22px;
            }

            .admin-menu-toggle {
                display: inline-flex;
            }

            .admin-links {
                width: 100%;
                display: none;
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
                padding-top: 8px;
            }

            .admin-links.open {
                display: flex;
            }

            .admin-header a {
                font-size: 14px;
            }

            .container {
                margin: 14px 12px;
                padding: 24px;
            }
        }
    </style>
</head>

<body>
    <div class="admin-header">
        <h1><span>59</span> Haber Kutusu - Hakkında Yönetimi</h1>
        <button type="button" class="admin-menu-toggle" id="adminMenuToggle" aria-label="Admin menü">&#9776;</button>
        <div id="adminLinks" class="admin-links">
            <a href="/<%= adminPath %>">Haberler</a>
            <a href="/<%= adminPath %>/kunye" style="color:#AB47BC;font-weight:600;">Künye</a>
            <a href="/<%= adminPath %>/ads" style="color:#42A5F5;font-weight:600;">Reklam (PC)</a>
            <a href="/<%= adminPath %>/ads-mobile" style="color:#66BB6A;font-weight:600;">Reklam (Mobil)</a>
            <a href="/<%= adminPath %>/ads-common" style="color:#FFB300;font-weight:600;">Reklam (Ortak)</a>
            <a href="/<%= adminPath %>/scraper" style="color:#66BB6A;font-weight:600;">Haber Çekici</a>
            <a href="/">Siteye Dön</a>
            <a href="/<%= adminPath %>/cikis" style="color:#ef5350;">Çıkış Yap</a>
        </div>
    </div>

    <div class="container">
        <h2 class="title">Hakkında Sayfasını Düzenle</h2>
        <p class="hint">Paragrafları ayırmak için boş satır bırakın. Değişiklikler <strong>/hakkinda</strong> sayfasına
            yansır.</p>
        <form action="/api/hakkinda" method="POST">
            <div class="form-group">
                <label>Hakkında Metni</label>
                <textarea name="aboutText" required><%= about.aboutText %></textarea>
            </div>
            <div class="form-group">
                <label>Telif Hakkı Metni</label>
                <textarea name="copyrightText" required><%= about.copyrightText %></textarea>
            </div>
            <button type="submit" class="btn-submit">Hakkında Bilgilerini Kaydet</button>
        </form>
    </div>

    <script>
        (function () {
            var adminMenuToggle = document.getElementById('adminMenuToggle');
            var adminLinks = document.getElementById('adminLinks');
            if (!adminMenuToggle || !adminLinks) return;
            adminMenuToggle.addEventListener('click', function () {
                adminLinks.classList.toggle('open');
            });
            window.addEventListener('resize', function () {
                if ((window.innerWidth || document.documentElement.clientWidth) > 768) {
                    adminLinks.classList.remove('open');
                }
            });
        })();
    </script>
</body>

</html>